# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

# aws_region has NO default — Terraform will prompt for it on every run unless
# you set it here. Uncomment + set to skip the prompt.
# aws_region     = "ap-southeast-2"

instance_name    = "python-coding-demo"
instance_type    = "t3.micro"
key_pair_name    = "python-coding-key"

# Path to your SSH PUBLIC key (the .pub file is safe; private key stays local).
# Generate one if you don't have it:
#   ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N ""
public_key_path  = "~/.ssh/id_ed25519.pub"

# Restrict SSH to your current public IP.
# Find it with: curl -s https://checkip.amazonaws.com
allowed_ssh_cidr = "REPLACE_WITH_YOUR_IP/32"
